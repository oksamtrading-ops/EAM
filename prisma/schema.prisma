  DEFERRED
}

// ============================================================
// MODULE 4: TECH RADAR
// ============================================================

model TechRadarEntry {
  id              String        @id @default(cuid())
  workspaceId     String
  techComponentId String?
  name            String
  quadrant        RadarQuadrant
  ring            RadarRing
  description     String?
  rationale       String?
  isNew           Boolean       @default(false)
  movedFrom       RadarRing?
  reviewedAt      DateTime?
  reviewedById    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  workspace        Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  reviewedBy       User?                 @relation("RadarReviewer", fields: [reviewedById], references: [id])
  applicationLinks ApplicationTechLink[]

  @@unique([workspaceId, name])
  @@index([workspaceId, ring])
  @@index([workspaceId, quadrant])
  @@map("tech_radar_entries")
}

// ============================================================
// MODULE 4: TECH RISK
// ============================================================

model TechRisk {
  id              String         @id @default(cuid())
  workspaceId     String
  title           String
  description     String?
  category        RiskCategory
  likelihood      RiskLikelihood
  impact          RiskImpact
  riskScore       Int
  status          RiskStatus     @default(OPEN)
  ownerId         String?
  dueDate         DateTime?
  identifiedAt    DateTime       @default(now())
  closedAt        DateTime?
  isAutoGenerated Boolean        @default(false)
  sourceType      String?
  sourceEntityId  String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  workspace        Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner            User?                 @relation("RiskOwner", fields: [ownerId], references: [id])
  applicationLinks RiskApplicationLink[]
  capabilityLinks  RiskCapabilityLink[]
  remediations     RiskRemediation[]
  tags             RiskTagMap[]

  @@index([workspaceId, status])
  @@index([workspaceId, category])
  @@index([workspaceId, riskScore])
  @@map("tech_risks")
}

model RiskApplicationLink {
  riskId        String
  applicationId String
  workspaceId   String
  notes         String?
  assignedAt    DateTime @default(now())

  risk TechRisk @relation(fields: [riskId], references: [id], onDelete: Cascade)

  @@id([riskId, applicationId])
  @@index([workspaceId, applicationId])
  @@map("risk_application_links")
}

model RiskCapabilityLink {
  riskId       String
  capabilityId String
  workspaceId  String
  notes        String?
  assignedAt   DateTime @default(now())

  risk TechRisk @relation(fields: [riskId], references: [id], onDelete: Cascade)

  @@id([riskId, capabilityId])
  @@index([workspaceId, capabilityId])
  @@map("risk_capability_links")
}

model RiskRemediation {
  id              String          @id @default(cuid())
  riskId          String
  workspaceId     String
  remediationType RemediationType
  initiativeId    String?
  description     String?
  targetDate      DateTime?
  completedDate   DateTime?
  createdAt       DateTime        @default(now())

  risk TechRisk @relation(fields: [riskId], references: [id], onDelete: Cascade)

  @@index([riskId])
  @@index([workspaceId])
  @@map("risk_remediations")
}

// ============================================================
// MODULE 4: RISK TAGS
// ============================================================

model RiskTag {
  id          String @id @default(cuid())
  workspaceId String
  name        String
  color       String @default("#6366f1")

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  mappings  RiskTagMap[]

  @@unique([workspaceId, name])
  @@map("risk_tags")
}

model RiskTagMap {
  riskId     String
  tagId      String
  assignedAt DateTime @default(now())

  risk TechRisk @relation(fields: [riskId], references: [id], onDelete: Cascade)
  tag  RiskTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([riskId, tagId])
  @@map("risk_tag_maps")
}

// ============================================================
// MODULE 4: COMPLIANCE
// ============================================================

model ComplianceRequirement {
  id             String              @id @default(cuid())
  workspaceId    String
  framework      ComplianceFramework
  controlId      String
  title          String
  description    String?
  category       String?
  isApplicable   Boolean             @default(true)
  isMandatory    Boolean             @default(true)
  auditFrequency String?
  evidenceNotes  String?
  sortOrder      Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  workspace Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  mappings  ComplianceMapping[]

  @@unique([workspaceId, framework, controlId])
  @@index([workspaceId, framework])
  @@map("compliance_requirements")
}

model ComplianceMapping {
  id             String                  @id @default(cuid())
  requirementId  String
  workspaceId    String
  entityType     String
  entityId       String
  entityName     String
  status         ComplianceMappingStatus @default(NOT_ASSESSED)
  evidence       String?
  assessedById   String?
  assessedAt     DateTime?
  nextReviewDate DateTime?
  notes          String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  requirement ComplianceRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  assessedBy  User?                 @relation("ComplianceAssessor", fields: [assessedById], references: [id])

  @@unique([requirementId, entityType, entityId])
  @@index([workspaceId, requirementId])
  @@map("compliance_mappings")
}

// ============================================================
// MODULE 4: EOL WATCH
// ============================================================

model EolWatchEntry {
  id                      String    @id @default(cuid())
  workspaceId             String
  entityType              String
  entityId                String
  entityName              String
  eolDate                 DateTime?
  eosDate                 DateTime?
  vendor                  String?
  affectedAppCount        Int       @default(0)
  urgencyBand             String    @default("HEALTHY")
  remediationInitiativeId String?
  isAcknowledged          Boolean   @default(false)
  acknowledgedById        String?
  acknowledgedAt          DateTime?
  notes                   String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  acknowledgedBy User?     @relation("EolAcknowledger", fields: [acknowledgedById], references: [id])

  @@unique([workspaceId, entityType, entityId])
  @@index([workspaceId, urgencyBand])
  @@map("eol_watch_entries")
}

// ============================================================
// DASHBOARD PINS
// ============================================================

model DashboardPin {
  id          String   @id @default(cuid())
  workspaceId String
  entityType  String
  entityId    String
  label       String
  href        String
  createdAt   DateTime @default(now())
  createdById String

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation(fields: [createdById], references: [id])

  @@unique([workspaceId, entityType, entityId])
  @@index([workspaceId])
  @@map("dashboard_pins")
}

// ============================================================
// SAVED PALETTE QUERIES (Cmd+K favorites)
// ============================================================

model SavedPaletteQuery {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  label       String
  queryText   String
  useCount    Int       @default(0)
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, userId])
  @@map("saved_palette_queries")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id          String      @id @default(cuid())
  workspaceId String
  userId      String?
  action      AuditAction
  entityType  String
  entityId    String
  before      Json?
  after       Json?
  createdAt   DateTime    @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id])

  @@index([workspaceId, entityType])
  @@index([workspaceId, createdAt])
  @@map("audit_logs")
}

// ============================================================
// MODULE 6: DATA ARCHITECTURE
// ============================================================

model DataDomain {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  ownerId     String?
  stewardId   String?
  color       String   @default("#0B5CD6")
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner     User?        @relation("DataDomainOwner", fields: [ownerId], references: [id])
  steward   User?        @relation("DataDomainSteward", fields: [stewardId], references: [id])
  entities  DataEntity[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("data_domains")
}

model DataEntity {
  id                String             @id @default(cuid())
  workspaceId       String
  domainId          String
  name              String
  description       String?
  entityType        DataEntityType     @default(TRANSACTIONAL)
  classification    DataClassification @default(DC_UNKNOWN)
  regulatoryTags    RegulatoryTag[]    @default([])
  goldenSourceAppId String?
  retentionDays     Int?
  stewardId         String?
  businessOwnerId   String?
  custodianId       String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  workspace       Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  domain          DataDomain          @relation(fields: [domainId], references: [id], onDelete: Restrict)
  goldenSourceApp Application?        @relation("DataEntityGoldenSource", fields: [goldenSourceAppId], references: [id])
  steward         User?               @relation("DataEntitySteward", fields: [stewardId], references: [id])
  businessOwner   User?               @relation("DataEntityBusinessOwner", fields: [businessOwnerId], references: [id])
  custodian       User?               @relation("DataEntityCustodian", fields: [custodianId], references: [id])
  appUsages       AppEntityUsage[]
  qualityScores   DataQualityScore[]
  attributes      DataAttribute[]
  interfaceFlows  InterfaceDataFlow[]

  @@unique([workspaceId, domainId, name])
  @@index([workspaceId])
  @@index([workspaceId, domainId])
  @@index([workspaceId, classification])
  @@map("data_entities")
}

model AppEntityUsage {
  id          String   @id @default(cuid())
  workspaceId String
  appId       String
  entityId    String
  creates     Boolean  @default(false)
  reads       Boolean  @default(false)
  updates     Boolean  @default(false)
  deletes     Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  app       Application @relation(fields: [appId], references: [id], onDelete: Cascade)
  entity    DataEntity  @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([appId, entityId])
  @@index([workspaceId])
  @@index([workspaceId, appId])
  @@index([workspaceId, entityId])
  @@map("app_entity_usages")
}

model DataQualityScore {
  id        String               @id @default(cuid())
  entityId  String
  dimension DataQualityDimension
  score     Int
  note      String?
  asOf      DateTime             @default(now())

  entity DataEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([entityId, dimension])
  @@map("data_quality_scores")
}

// Field-level schema under a DataEntity. fkTargetEntityId is a soft
// reference — no DB foreign key — so xlsx imports can tolerate forward
// references and cross-entity renames. The router validates existence
// when non-null.
model DataAttribute {
  id               String             @id @default(cuid())
  workspaceId      String
  entityId         String
  name             String
  dataType         String
  isNullable       Boolean            @default(true)
  isPrimaryKey     Boolean            @default(false)
  isForeignKey     Boolean            @default(false)
  fkTargetEntityId String?
  classification   DataClassification @default(DC_UNKNOWN)
  regulatoryTags   RegulatoryTag[]    @default([])
  description      String?
  sortOrder        Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  entity    DataEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, name])
  @@index([workspaceId, entityId])
  @@map("data_attributes")
}

// ============================================================
// INTERFACE DATA FLOWS (shared M2/M6)
// ============================================================

// Join table: which DataEntities flow across which ApplicationInterface.
model InterfaceDataFlow {
  id           String            @id @default(cuid())
  workspaceId  String
  interfaceId  String
  dataEntityId String
  direction    DataFlowDirection @default(SOURCE_TO_TARGET)
  frequency    String?
  notes        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  workspace Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  interface ApplicationInterface @relation(fields: [interfaceId], references: [id], onDelete: Cascade)
  entity    DataEntity           @relation(fields: [dataEntityId], references: [id], onDelete: Cascade)

  @@unique([interfaceId, dataEntityId])
  @@index([workspaceId])
  @@index([workspaceId, interfaceId])
  @@index([workspaceId, dataEntityId])
  @@map("interface_data_flows")
}

