// ============================================================
// EAM PLATFORM — PRISMA SCHEMA (POC)
// Module 1: Business Capability Map
// Stack: PostgreSQL + pgvector (Neon)
// ============================================================

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

// ============================================================
// ENUMS
// ============================================================

enum IndustryType {
  BANKING
  RETAIL
  LOGISTICS
  MANUFACTURING
  HEALTHCARE
  GENERIC
  ENTERPRISE_BCM
  INSURANCE
  TELECOM
  ENERGY_UTILITIES
  PUBLIC_SECTOR
  PHARMA_LIFESCIENCES
}

enum CapabilityLevel {
  L1
  L2
  L3
}

enum StrategicImportance {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  NOT_ASSESSED
}

enum MaturityLevel {
  INITIAL
  DEVELOPING
  DEFINED
  MANAGED
  OPTIMIZING
  NOT_ASSESSED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  IMPORT
  ASSESS
}

// ============================================================
// MODULE 2 ENUMS
// ============================================================

enum ApplicationLifecycle {
  PLANNED
  ACTIVE
  PHASING_OUT
  RETIRED
  SUNSET
}

enum ApplicationType {
  SAAS
  COTS
  CUSTOM
  PAAS
  OPEN_SOURCE
  LEGACY
}

enum DeploymentModel {
  CLOUD_PUBLIC
  CLOUD_PRIVATE
  ON_PREMISE
  HYBRID
  SAAS_HOSTED
  UNKNOWN
}

enum BusinessValueScore {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  BV_UNKNOWN
}

enum TechnicalHealthScore {
  EXCELLENT
  GOOD
  FAIR
  POOR
  TH_CRITICAL
  TH_UNKNOWN
}

enum RationalizationStatus {
  TOLERATE
  INVEST
  MIGRATE
  ELIMINATE
  RAT_NOT_ASSESSED
}

enum CostModel {
  LICENSE_PER_USER
  LICENSE_FLAT
  SUBSCRIPTION
  USAGE_BASED
  OPEN_SOURCE
  INTERNAL
}

// ============================================================
// AI MAPPING ENUMS
// ============================================================

enum MappingSource {
  MANUAL
  AI_SUGGESTED
  AI_ACCEPTED
  AI_MODIFIED
  IMPORTED
}

enum RelationshipType {
  PRIMARY
  SUPPORTING
  ENABLING
}

enum Region {
  NA
  EMEA
  APAC
  LATAM
  GLOBAL
}

enum FeedbackAction {
  ACCEPTED
  REJECTED
  MODIFIED
}

// ============================================================
// APPLICATION PORTFOLIO GAP-FILL ENUMS
// ============================================================

enum FunctionalFitScore {
  EXCELLENT
  GOOD
  ADEQUATE
  POOR
  UNFIT
  FF_UNKNOWN
}

enum DataClassification {
  PUBLIC
  INTERNAL
  CONFIDENTIAL
  RESTRICTED
  DC_UNKNOWN
}

enum InterfaceProtocol {
  REST_API
  SOAP
  GRAPHQL
  FILE_TRANSFER
  DATABASE_LINK
  MESSAGE_QUEUE
  EVENT_STREAM
  ETL
  SFTP
  CUSTOM
}

enum InterfaceDirection {
  INBOUND
  OUTBOUND
  BIDIRECTIONAL
}

enum InterfaceStatus {
  INT_ACTIVE
  INT_PLANNED
  INT_DEPRECATED
  INT_DECOMMISSIONED
}

enum InterfaceCriticality {
  INT_CRITICAL
  INT_HIGH
  INT_MEDIUM
  INT_LOW
}


// Direction a data entity flows across an interface.
enum DataFlowDirection {
  SOURCE_TO_TARGET
  TARGET_TO_SOURCE
  BIDIRECTIONAL
}

// ============================================================
// MODULE 6 ENUMS (Data Architecture)
// ============================================================

enum DataEntityType {
  MASTER
  REFERENCE
  TRANSACTIONAL
  ANALYTICAL
  METADATA
}

enum RegulatoryTag {
  PII
  PHI
  PCI
  GDPR
  CCPA
  SOX
  HIPAA
  FERPA
}

enum DataQualityDimension {
  COMPLETENESS
  ACCURACY
  CONSISTENCY
  TIMELINESS
  UNIQUENESS
  VALIDITY
}

// ============================================================
// USER (synced from Clerk)
// ============================================================

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaces                  Workspace[]
  ownedCapabilities           BusinessCapability[]   @relation("CapabilityOwner")
  businessOwnedCaps           BusinessCapability[]   @relation("CapabilityBusinessOwner")
  itOwnedCaps                 BusinessCapability[]   @relation("CapabilityITOwner")
  auditLogs                   AuditLog[]
  createdVersions             CapabilityMapVersion[]
  ownedApplications           Application[]          @relation("AppOwner")
  businessOwnedApps           Application[]          @relation("AppBusinessOwner")
  itOwnedApps                 Application[]          @relation("AppITOwner")
  ownedInitiatives            Initiative[]           @relation("InitiativeOwner")
  ownedObjectives             Objective[]            @relation("ObjectiveOwner")
  ownedMilestones             Milestone[]            @relation("MilestoneOwner")
  createdArchStates           ArchitectureState[]    @relation("ArchStateCreator")
  ownedRisks                  TechRisk[]             @relation("RiskOwner")
  reviewedRadarEntries        TechRadarEntry[]       @relation("RadarReviewer")
  assessedMappings            ComplianceMapping[]    @relation("ComplianceAssessor")
  acknowledgedEolEntries      EolWatchEntry[]        @relation("EolAcknowledger")
  dashboardPins               DashboardPin[]
  ownedDataDomains            DataDomain[]           @relation("DataDomainOwner")
  stewardedDataDomains        DataDomain[]           @relation("DataDomainSteward")
  stewardedDataEntities       DataEntity[]           @relation("DataEntitySteward")
  dataEntitiesAsBusinessOwner DataEntity[]           @relation("DataEntityBusinessOwner")
  dataEntitiesAsCustodian     DataEntity[]           @relation("DataEntityCustodian")
  ownedVendors                Vendor[]               @relation("VendorRelationshipOwner")
  ownedTechnologyComponents   TechnologyComponent[]  @relation("TechnologyComponentOwner")
  ownedTechnologyStandards    TechnologyStandard[]   @relation("TechnologyStandardOwner")
  ownedReferenceArchitectures ReferenceArchitecture[] @relation("ReferenceArchitectureOwner")
  agentConversations          AgentConversation[]
  agentConversationShares     AgentConversationShare[]
  scheduledAgentTasks         ScheduledAgentTask[]

  @@map("users")
}

// ============================================================
// WORKSPACE (single default for POC)
// ============================================================

model Workspace {
  id                String       @id @default(cuid())
  slug              String       @unique
  name              String
  clientName        String?
  description       String?
  industry          IndustryType @default(GENERIC)
  subIndustry       String?
  region            Region?
  regulatoryRegime  String?
  businessModelHint String?
  itVision          String?
  missionStatement  String?
  logoUrl           String?
  // Hex accent color used on shared/share pages. null = fall back to
  // the default EAM purple (var(--ai)). Validated at the router.
  brandColor        String?
  isDefault         Boolean      @default(false)
  isActive          Boolean      @default(true)
  userId            String
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  user                   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  capabilities           BusinessCapability[]
  organizations          Organization[]
  auditLogs              AuditLog[]
  tags                   CapabilityTag[]
  versions               CapabilityMapVersion[]
  applications           Application[]
  initiatives            Initiative[]
  objectives             Objective[]
  archStates             ArchitectureState[]
  initiativeTags         InitiativeTag[]
  techRisks              TechRisk[]
  techRadarEntries       TechRadarEntry[]
  complianceRequirements ComplianceRequirement[]
  eolWatchEntries        EolWatchEntry[]
  riskTags               RiskTag[]
  dashboardPins          DashboardPin[]
  aiMappingFeedback      AIMappingFeedback[]
  aiMappingRuns          AIMappingRun[]
  savedPaletteQueries    SavedPaletteQuery[]
  valueStreams           ValueStream[]
  applicationInterfaces  ApplicationInterface[]
  applicationTechLinks   ApplicationTechLink[]
  dataDomains            DataDomain[]
  dataEntities           DataEntity[]
  dataAttributes         DataAttribute[]
  appEntityUsages        AppEntityUsage[]
  interfaceDataFlows     InterfaceDataFlow[]
  vendors                Vendor[]
  technologyProducts     TechnologyProduct[]
  technologyVersions     TechnologyVersion[]
  technologyComponents   TechnologyComponent[]
  technologyDependencies TechnologyDependency[]
  technologyStandards    TechnologyStandard[]
  referenceArchitectures ReferenceArchitecture[]
  intakeDocuments        IntakeDocument[]
  intakeDrafts           IntakeDraft[]
  agentRuns              AgentRun[]
  agentConversations     AgentConversation[]
  workspaceKnowledge     WorkspaceKnowledge[]
  knowledgeDrafts        KnowledgeDraft[]
  scheduledAgentTasks    ScheduledAgentTask[]
  agentSettings          WorkspaceAgentSettings?

  @@map("workspaces")
}

// ============================================================
// ORGANIZATION (Business Unit)
// ============================================================

model Organization {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  parentId    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace    Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent       Organization?        @relation("OrgHierarchy", fields: [parentId], references: [id])
  children     Organization[]       @relation("OrgHierarchy")
  capabilities BusinessCapability[]

  @@map("organizations")
}

// ============================================================
// VALUE STREAM
// ============================================================

model ValueStream {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  color       String   @default("#0B5CD6")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace    Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  capabilities BusinessCapability[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("value_streams")
}

// ============================================================
// BUSINESS CAPABILITY
// ============================================================

model BusinessCapability {
  id                  String              @id @default(cuid())
  workspaceId         String
  parentId            String?
  level               CapabilityLevel     @default(L1)
  name                String
  description         String?
  ownerId             String?
  businessOwnerId     String?
  itOwnerId           String?
  organizationId      String?
  valueStreamId       String?
  strategicImportance StrategicImportance @default(NOT_ASSESSED)
  currentMaturity     MaturityLevel       @default(NOT_ASSESSED)
  targetMaturity      MaturityLevel       @default(NOT_ASSESSED)
  sortOrder           Int                 @default(0)
  isActive            Boolean             @default(true)
  externalId          String?

  embedding Unsupported("vector(1536)")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace           Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent              BusinessCapability?        @relation("CapabilityTree", fields: [parentId], references: [id])
  children            BusinessCapability[]       @relation("CapabilityTree")
  owner               User?                      @relation("CapabilityOwner", fields: [ownerId], references: [id])
  businessOwner       User?                      @relation("CapabilityBusinessOwner", fields: [businessOwnerId], references: [id])
  itOwner             User?                      @relation("CapabilityITOwner", fields: [itOwnerId], references: [id])
  organization        Organization?              @relation(fields: [organizationId], references: [id])
  valueStream         ValueStream?               @relation(fields: [valueStreamId], references: [id])
  tags                CapabilityTagMap[]
  assessments         CapabilityAssessment[]
  applicationMappings ApplicationCapabilityMap[]
  objectives          CapabilityObjectiveMap[]
  dependsOn           CapabilityDependency[]     @relation("DependentCapability")
  dependedOnBy        CapabilityDependency[]     @relation("PrerequisiteCapability")

  @@index([workspaceId])
  @@index([workspaceId, parentId])
  @@index([workspaceId, level])
  @@map("business_capabilities")
}

// ============================================================
// TAGS
// ============================================================

model CapabilityTag {
  id          String  @id @default(cuid())
  workspaceId String
  name        String
  color       String  @default("#6366f1")
  description String?

  workspace Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  mappings  CapabilityTagMap[]

  @@unique([workspaceId, name])
  @@map("capability_tags")
}

model CapabilityTagMap {
  capabilityId String
  tagId        String
  assignedAt   DateTime @default(now())

  capability BusinessCapability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)
  tag        CapabilityTag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([capabilityId, tagId])
  @@map("capability_tag_maps")
}

// ============================================================
// CAPABILITY ASSESSMENT
// ============================================================

model CapabilityAssessment {
  id                  String              @id @default(cuid())
  capabilityId        String
  assessedById        String?
  currentMaturity     MaturityLevel
  targetMaturity      MaturityLevel
  strategicImportance StrategicImportance
  notes               String?
  assessedAt          DateTime            @default(now())

  capability BusinessCapability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@index([capabilityId])
  @@map("capability_assessments")
}

// ============================================================
// CAPABILITY ↔ OBJECTIVE (direct strategic alignment)
// ============================================================

enum AlignmentStrength {
  STRONG
  MODERATE
  WEAK
}

model CapabilityObjectiveMap {
  capabilityId String
  objectiveId  String
  alignment    AlignmentStrength @default(MODERATE)
  notes        String?
  assignedAt   DateTime          @default(now())

  capability BusinessCapability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)
  objective  Objective          @relation(fields: [objectiveId], references: [id], onDelete: Cascade)

  @@id([capabilityId, objectiveId])
  @@map("capability_objective_maps")
}

// ============================================================
// CAPABILITY ↔ CAPABILITY DEPENDENCY
// ============================================================

model CapabilityDependency {
  id             String   @id @default(cuid())
  workspaceId    String
  dependentId    String
  prerequisiteId String
  description    String?
  createdAt      DateTime @default(now())

  dependent    BusinessCapability @relation("DependentCapability", fields: [dependentId], references: [id], onDelete: Cascade)
  prerequisite BusinessCapability @relation("PrerequisiteCapability", fields: [prerequisiteId], references: [id], onDelete: Cascade)

  @@unique([dependentId, prerequisiteId])
  @@index([workspaceId])
  @@map("capability_dependencies")
}

// ============================================================
// INDUSTRY TEMPLATES
// ============================================================

model CapabilityTemplate {
  id                  String              @id @default(cuid())
  industry            IndustryType
  level               CapabilityLevel
  name                String
  description         String?
  parentCode          String?
  code                String              @unique
  sortOrder           Int                 @default(0)
  isActive            Boolean             @default(true)
  strategicImportance StrategicImportance @default(NOT_ASSESSED)
  band                String?

  @@index([industry, level])
  @@map("capability_templates")
}

// ============================================================
// MODULE 2: APPLICATION
// ============================================================

model Application {
  id                         String                @id @default(cuid())
  workspaceId                String
  name                       String
  description                String?
  alias                      String?
  vendor                     String?
  version                    String?
  applicationType            ApplicationType       @default(CUSTOM)
  deploymentModel            DeploymentModel       @default(UNKNOWN)
  lifecycle                  ApplicationLifecycle  @default(ACTIVE)
  lifecycleStartDate         DateTime?
  lifecycleEndDate           DateTime?
  businessValue              BusinessValueScore    @default(BV_UNKNOWN)
  technicalHealth            TechnicalHealthScore  @default(TH_UNKNOWN)
  rationalizationStatus      RationalizationStatus @default(RAT_NOT_ASSESSED)
  rationalizationNotes       String?
  annualCostUsd              Decimal?              @db.Decimal(14, 2)
  costCurrency               String                @default("USD")
  costModel                  CostModel?
  costNotes                  String?
  costRenewalDate            DateTime?
  licensedUsers              Int?
  businessOwnerName          String?
  itOwnerName                String?
  businessOwnerId            String?
  itOwnerId                  String?
  ownerId                    String?
  // --- AI-critical fields for TIME rationalization ---
  functionalFit              FunctionalFitScore    @default(FF_UNKNOWN)
  dataClassification         DataClassification    @default(DC_UNKNOWN)
  actualUsers                Int?
  replacementAppId           String?
  sortOrder                  Int                   @default(0)
  isActive                   Boolean               @default(true)
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt

  workspace            Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner                User?                      @relation("AppOwner", fields: [ownerId], references: [id])
  businessOwner        User?                      @relation("AppBusinessOwner", fields: [businessOwnerId], references: [id])
  itOwner              User?                      @relation("AppITOwner", fields: [itOwnerId], references: [id])
  replacementApp       Application?               @relation("ReplacementTarget", fields: [replacementAppId], references: [id])
  replacedBy           Application[]              @relation("ReplacementTarget")
  capabilities         ApplicationCapabilityMap[]
  assessments          ApplicationAssessment[]
  techStackLinks       ApplicationTechLink[]
  interfacesFrom       ApplicationInterface[]     @relation("InterfaceSource")
  interfacesTo         ApplicationInterface[]     @relation("InterfaceTarget")
  entityUsages         AppEntityUsage[]
  goldenSourceEntities DataEntity[]               @relation("DataEntityGoldenSource")
  technologyComponents ApplicationTechnology[]

  @@index([workspaceId])
  @@index([workspaceId, lifecycle])
  @@index([workspaceId, rationalizationStatus])
  @@index([workspaceId, functionalFit])
  @@map("applications")
}

// ============================================================
// APPLICATION ↔ CAPABILITY MAPPING
// ============================================================

model ApplicationCapabilityMap {
  applicationId String
  capabilityId  String
  workspaceId   String
  supportType   String   @default("SUPPORTS")
  notes         String?
  assignedAt    DateTime @default(now())

  // AI mapping metadata
  source           MappingSource    @default(MANUAL)
  relationshipType RelationshipType @default(PRIMARY)
  aiConfidence     Int?
  aiRationale      String?
  aiModel          String?
  aiPromptVersion  String?
  createdById      String?

  application Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  capability  BusinessCapability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@id([applicationId, capabilityId])
  @@index([workspaceId, capabilityId])
  @@map("application_capability_maps")
}

// ============================================================
// AI MAPPING FEEDBACK (closed-loop learning)
// ============================================================

model AIMappingFeedback {
  id                   String            @id @default(cuid())
  workspaceId          String
  applicationId        String
  capabilityId         String
  aiConfidence         Int
  aiRationale          String
  aiRelationshipType   RelationshipType
  userAction           FeedbackAction
  userRelationshipType RelationshipType?
  userCapabilityId     String?
  userNote             String?
  promptVersion        String
  model                String
  tier                 String
  createdAt            DateTime          @default(now())
  createdById          String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([applicationId])
  @@index([capabilityId])
  @@map("ai_mapping_feedback")
}

// ============================================================
// AI MAPPING RUN (telemetry + rate limit accounting)
// ============================================================

model AIMappingRun {
  id                   String   @id @default(cuid())
  workspaceId          String
  mode                 String
  tier                 String
  appsProcessed        Int      @default(0)
  suggestionsGenerated Int      @default(0)
  tokensUsed           Int      @default(0)
  durationMs           Int      @default(0)
  model                String
  promptVersion        String
  status               String   @default("completed")
  errorMessage         String?
  createdAt            DateTime @default(now())
  createdById          String?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@map("ai_mapping_runs")
}

// ============================================================
// APPLICATION ASSESSMENT
// ============================================================

model ApplicationAssessment {
  id                    String                @id @default(cuid())
  applicationId         String
  assessedById          String?
  businessValue         BusinessValueScore
  technicalHealth       TechnicalHealthScore
  rationalizationStatus RationalizationStatus
  functionalFit         FunctionalFitScore?
  notes                 String?
  assessedAt            DateTime              @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("application_assessments")
}

// ============================================================
// APPLICATION INTERFACE (Integration Catalogue)
// ============================================================

model ApplicationInterface {
  id                  String               @id @default(cuid())
  workspaceId         String
  sourceAppId         String
  targetAppId         String
  name                String
  description         String?
  protocol            InterfaceProtocol    @default(REST_API)
  direction           InterfaceDirection   @default(OUTBOUND)
  status              InterfaceStatus      @default(INT_ACTIVE)
  criticality         InterfaceCriticality @default(INT_MEDIUM)
  dataFlowDescription String?
  frequency           String?
  dataClassification  DataClassification?
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  workspace Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceApp Application         @relation("InterfaceSource", fields: [sourceAppId], references: [id], onDelete: Cascade)
  targetApp Application         @relation("InterfaceTarget", fields: [targetAppId], references: [id], onDelete: Cascade)
  dataFlows InterfaceDataFlow[]

  @@unique([workspaceId, sourceAppId, targetAppId, name], map: "application_interfaces_ws_src_tgt_name_key")
  @@index([workspaceId])
  @@index([sourceAppId])
  @@index([targetAppId])
  @@map("application_interfaces")
}

// ============================================================
// APPLICATION ↔ TECH RADAR LINK (Tech Stack Decomposition)
// ============================================================

model ApplicationTechLink {
  applicationId    String
  techRadarEntryId String
  workspaceId      String
  layer            String   @default("APPLICATION")
  notes            String?
  assignedAt       DateTime @default(now())

  application    Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  techRadarEntry TechRadarEntry @relation(fields: [techRadarEntryId], references: [id], onDelete: Cascade)
  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([applicationId, techRadarEntryId])
  @@index([workspaceId])
  @@map("application_tech_links")
}

// ============================================================
// CAPABILITY MAP VERSIONING
// ============================================================

model CapabilityMapVersion {
  id          String   @id @default(cuid())
  workspaceId String
  label       String
  description String?
  snapshot    Json
  createdById String?
  isAutomatic Boolean  @default(false)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User?     @relation(fields: [createdById], references: [id])

  @@index([workspaceId, createdAt])
  @@map("capability_map_versions")
}

// ============================================================
// MODULE 3 ENUMS
// ============================================================

enum InitiativeStatus {
  DRAFT
  PLANNED
  IN_PROGRESS
  ON_HOLD
  COMPLETE
  CANCELLED
}

enum InitiativePriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum InitiativeCategory {
  MODERNISATION
  CONSOLIDATION
  DIGITALISATION
  COMPLIANCE
  OPTIMISATION
  INNOVATION
  DECOMMISSION
}

enum MilestoneStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
  BLOCKED
  CANCELLED
}

enum ArchStateType {
  AS_IS
  TO_BE
}

enum DependencyType {
  FINISH_TO_START
  FINISH_TO_FINISH
  START_TO_START
}

enum RoadmapHorizon {
  H1_NOW
  H2_NEXT
  H3_LATER
  BEYOND
}

// ============================================================
// MODULE 3: OBJECTIVE
// ============================================================

model Objective {
  id             String    @id @default(cuid())
  workspaceId    String
  name           String
  description    String?
  targetDate     DateTime?
  kpiDescription String?
  kpiTarget      String?
  ownerId        String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  workspace    Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner        User?                    @relation("ObjectiveOwner", fields: [ownerId], references: [id])
  initiatives  InitiativeObjectiveMap[]
  capabilities CapabilityObjectiveMap[]

  @@index([workspaceId])
  @@map("objectives")
}

// ============================================================
// MODULE 3: INITIATIVE
// ============================================================

model Initiative {
  id                 String             @id @default(cuid())
  workspaceId        String
  name               String
  description        String?
  category           InitiativeCategory @default(MODERNISATION)
  status             InitiativeStatus   @default(DRAFT)
  priority           InitiativePriority @default(MEDIUM)
  horizon            RoadmapHorizon     @default(H2_NEXT)
  startDate          DateTime?
  endDate            DateTime?
  budgetUsd          Decimal?           @db.Decimal(14, 2)
  budgetCurrency     String             @default("USD")
  cancellationReason String?
  sourceType         String?
  sourceContext      String?
  ownerId            String?
  businessSponsor    String?
  progressPct        Int                @default(0)
  ragStatus          String             @default("GREEN")
  isActive           Boolean            @default(true)
  sortOrder          Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  workspace    Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner        User?                      @relation("InitiativeOwner", fields: [ownerId], references: [id])
  milestones   Milestone[]
  capabilities InitiativeCapabilityMap[]
  applications InitiativeApplicationMap[]
  objectives   InitiativeObjectiveMap[]
  dependsOn    InitiativeDependency[]     @relation("DependentInitiative")
  blockedBy    InitiativeDependency[]     @relation("BlockingInitiative")
  archStates   ArchitectureState[]
  tags         InitiativeTagMap[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([workspaceId, horizon])
  @@map("initiatives")
}

// ============================================================
// MODULE 3: MILESTONE
// ============================================================

model Milestone {
  id           String          @id @default(cuid())
  initiativeId String
  workspaceId  String
  name         String
  description  String?
  status       MilestoneStatus @default(NOT_STARTED)
  dueDate      DateTime?
  completedAt  DateTime?
  ownerId      String?
  sortOrder    Int             @default(0)
  isCritical   Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  initiative Initiative            @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  owner      User?                 @relation("MilestoneOwner", fields: [ownerId], references: [id])
  blockedBy  MilestoneDependency[] @relation("DependentMilestone")
  blocks     MilestoneDependency[] @relation("BlockingMilestone")

  @@index([initiativeId])
  @@index([workspaceId])
  @@map("milestones")
}

// ============================================================
// MODULE 3: DEPENDENCIES
// ============================================================

model InitiativeDependency {
  id             String         @id @default(cuid())
  workspaceId    String
  dependentId    String
  blockingId     String
  dependencyType DependencyType @default(FINISH_TO_START)
  lagDays        Int            @default(0)
  notes          String?
  createdAt      DateTime       @default(now())

  dependent Initiative @relation("DependentInitiative", fields: [dependentId], references: [id], onDelete: Cascade)
  blocking  Initiative @relation("BlockingInitiative", fields: [blockingId], references: [id], onDelete: Cascade)

  @@unique([dependentId, blockingId])
  @@index([workspaceId])
  @@map("initiative_dependencies")
}

model MilestoneDependency {
  dependentId String
  blockingId  String
  createdAt   DateTime @default(now())

  dependent Milestone @relation("DependentMilestone", fields: [dependentId], references: [id], onDelete: Cascade)
  blocking  Milestone @relation("BlockingMilestone", fields: [blockingId], references: [id], onDelete: Cascade)

  @@id([dependentId, blockingId])
  @@map("milestone_dependencies")
}

// ============================================================
// MODULE 3: INITIATIVE ↔ CAPABILITY MAP
// ============================================================

model InitiativeCapabilityMap {
  initiativeId    String
  capabilityId    String
  workspaceId     String
  impactType      String   @default("IMPROVES")
  currentMaturity String?
  targetMaturity  String?
  notes           String?
  assignedAt      DateTime @default(now())

  initiative Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)

  @@id([initiativeId, capabilityId])
  @@index([workspaceId, capabilityId])
  @@map("initiative_capability_maps")
}

// ============================================================
// MODULE 3: INITIATIVE ↔ APPLICATION MAP
// ============================================================

model InitiativeApplicationMap {
  initiativeId  String
  applicationId String
  workspaceId   String
  changeType    String   @default("MODIFIES")
  notes         String?
  assignedAt    DateTime @default(now())

  initiative Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)

  @@id([initiativeId, applicationId])
  @@index([workspaceId, applicationId])
  @@map("initiative_application_maps")
}

// ============================================================
// MODULE 3: OBJECTIVE ↔ INITIATIVE MAP
// ============================================================

model InitiativeObjectiveMap {
  initiativeId String
  objectiveId  String
