// ============================================================
// EAM PLATFORM — PRISMA SCHEMA (POC)
// Module 1: Business Capability Map
// Stack: PostgreSQL + pgvector (Neon)
// ============================================================

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

// ============================================================
// ENUMS
// ============================================================

enum IndustryType {
  BANKING
  RETAIL
  LOGISTICS
  MANUFACTURING
  HEALTHCARE
  GENERIC
  ENTERPRISE_BCM
}

enum CapabilityLevel {
  L1
  L2
  L3
}

enum StrategicImportance {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  NOT_ASSESSED
}

enum MaturityLevel {
  INITIAL
  DEVELOPING
  DEFINED
  MANAGED
  OPTIMIZING
  NOT_ASSESSED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  IMPORT
  ASSESS
}

// ============================================================
// MODULE 2 ENUMS
// ============================================================

enum ApplicationLifecycle {
  PLANNED
  ACTIVE
  PHASING_OUT
  RETIRED
  SUNSET
}

enum ApplicationType {
  SAAS
  COTS
  CUSTOM
  PAAS
  OPEN_SOURCE
  LEGACY
}

enum DeploymentModel {
  CLOUD_PUBLIC
  CLOUD_PRIVATE
  ON_PREMISE
  HYBRID
  SAAS_HOSTED
  UNKNOWN
}

enum BusinessValueScore {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  BV_UNKNOWN
}

enum TechnicalHealthScore {
  EXCELLENT
  GOOD
  FAIR
  POOR
  TH_CRITICAL
  TH_UNKNOWN
}

enum RationalizationStatus {
  KEEP
  INVEST
  MIGRATE
  RETIRE
  CONSOLIDATE
  EVALUATE
  RAT_NOT_ASSESSED
}

enum CostModel {
  LICENSE_PER_USER
  LICENSE_FLAT
  SUBSCRIPTION
  USAGE_BASED
  OPEN_SOURCE
  INTERNAL
}

// ============================================================
// USER (synced from Clerk)
// ============================================================

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaces          Workspace[]
  ownedCapabilities   BusinessCapability[]  @relation("CapabilityOwner")
  auditLogs           AuditLog[]
  createdVersions     CapabilityMapVersion[]
  ownedApplications   Application[]         @relation("AppOwner")
  ownedInitiatives    Initiative[]          @relation("InitiativeOwner")
  ownedObjectives     Objective[]           @relation("ObjectiveOwner")
  ownedMilestones     Milestone[]           @relation("MilestoneOwner")
  createdArchStates   ArchitectureState[]   @relation("ArchStateCreator")
  ownedRisks          TechRisk[]            @relation("RiskOwner")
  reviewedRadarEntries TechRadarEntry[]     @relation("RadarReviewer")
  assessedMappings    ComplianceMapping[]   @relation("ComplianceAssessor")
  acknowledgedEolEntries EolWatchEntry[]    @relation("EolAcknowledger")
  dashboardPins          DashboardPin[]

  @@map("users")
}

// ============================================================
// WORKSPACE (single default for POC)
// ============================================================

model Workspace {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  clientName  String?
  description String?
  industry    IndustryType @default(GENERIC)
  logoUrl     String?
  isDefault   Boolean      @default(false)
  isActive    Boolean      @default(true)
  userId      String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  capabilities   BusinessCapability[]
  organizations  Organization[]
  auditLogs      AuditLog[]
  tags           CapabilityTag[]
  versions       CapabilityMapVersion[]
  applications   Application[]
  initiatives    Initiative[]
  objectives     Objective[]
  archStates     ArchitectureState[]
  initiativeTags InitiativeTag[]
  techRisks          TechRisk[]
  techRadarEntries   TechRadarEntry[]
  complianceRequirements ComplianceRequirement[]
  eolWatchEntries    EolWatchEntry[]
  riskTags           RiskTag[]
  dashboardPins      DashboardPin[]

  @@map("workspaces")
}

// ============================================================
// ORGANIZATION (Business Unit)
// ============================================================

model Organization {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  parentId    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace    Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent       Organization?  @relation("OrgHierarchy", fields: [parentId], references: [id])
  children     Organization[] @relation("OrgHierarchy")
  capabilities BusinessCapability[]

  @@map("organizations")
}

// ============================================================
// BUSINESS CAPABILITY
// ============================================================

model BusinessCapability {
  id                  String              @id @default(cuid())
  workspaceId         String
  parentId            String?
  level               CapabilityLevel     @default(L1)
  name                String
  description         String?
  ownerId             String?
  organizationId      String?
  strategicImportance StrategicImportance @default(NOT_ASSESSED)
  currentMaturity     MaturityLevel       @default(NOT_ASSESSED)
  targetMaturity      MaturityLevel       @default(NOT_ASSESSED)
  sortOrder           Int                 @default(0)
  isActive            Boolean             @default(true)
  externalId          String?

  embedding Unsupported("vector(1536)")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace    Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent       BusinessCapability?  @relation("CapabilityTree", fields: [parentId], references: [id])
  children     BusinessCapability[] @relation("CapabilityTree")
  owner        User?                @relation("CapabilityOwner", fields: [ownerId], references: [id])
  organization Organization?        @relation(fields: [organizationId], references: [id])
  tags         CapabilityTagMap[]
  assessments  CapabilityAssessment[]
  applicationMappings ApplicationCapabilityMap[]

  @@index([workspaceId])
  @@index([workspaceId, parentId])
  @@index([workspaceId, level])
  @@map("business_capabilities")
}

// ============================================================
// TAGS
// ============================================================

model CapabilityTag {
  id          String  @id @default(cuid())
  workspaceId String
  name        String
  color       String  @default("#6366f1")
  description String?

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  mappings  CapabilityTagMap[]

  @@unique([workspaceId, name])
  @@map("capability_tags")
}

model CapabilityTagMap {
  capabilityId String
  tagId        String
  assignedAt   DateTime @default(now())

  capability BusinessCapability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)
  tag        CapabilityTag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([capabilityId, tagId])
  @@map("capability_tag_maps")
}

// ============================================================
// CAPABILITY ASSESSMENT
// ============================================================

model CapabilityAssessment {
  id                  String              @id @default(cuid())
  capabilityId        String
  assessedById        String?
  currentMaturity     MaturityLevel
  targetMaturity      MaturityLevel
  strategicImportance StrategicImportance
  notes               String?
  assessedAt          DateTime            @default(now())

  capability BusinessCapability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@index([capabilityId])
  @@map("capability_assessments")
}

// ============================================================
// INDUSTRY TEMPLATES
// ============================================================

model CapabilityTemplate {
  id                  String              @id @default(cuid())
  industry            IndustryType
  level               CapabilityLevel
  name                String
  description         String?
  parentCode          String?
  code                String              @unique
  sortOrder           Int                 @default(0)
  isActive            Boolean             @default(true)
  strategicImportance StrategicImportance @default(NOT_ASSESSED)
  band                String?

  @@index([industry, level])
  @@map("capability_templates")
}

// ============================================================
// MODULE 2: APPLICATION
// ============================================================

model Application {
  id                    String                @id @default(cuid())
  workspaceId           String
  name                  String
  description           String?
  alias                 String?
  vendor                String?
  version               String?
  applicationType       ApplicationType       @default(CUSTOM)
  deploymentModel       DeploymentModel       @default(UNKNOWN)
  lifecycle             ApplicationLifecycle  @default(ACTIVE)
  lifecycleStartDate    DateTime?
  lifecycleEndDate      DateTime?
  businessValue         BusinessValueScore    @default(BV_UNKNOWN)
  technicalHealth       TechnicalHealthScore  @default(TH_UNKNOWN)
  rationalizationStatus RationalizationStatus @default(RAT_NOT_ASSESSED)
  rationalizationNotes  String?
  annualCostUsd         Decimal?              @db.Decimal(14, 2)
  costCurrency          String                @default("USD")
  costModel             CostModel?
  costNotes             String?
  costRenewalDate       DateTime?
  licensedUsers         Int?
  businessOwnerName     String?
  itOwnerName           String?
  ownerId               String?
  sortOrder             Int                   @default(0)
  isActive              Boolean               @default(true)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  workspace    Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner        User?                    @relation("AppOwner", fields: [ownerId], references: [id])
  capabilities ApplicationCapabilityMap[]
  assessments  ApplicationAssessment[]

  @@index([workspaceId])
  @@index([workspaceId, lifecycle])
  @@index([workspaceId, rationalizationStatus])
  @@map("applications")
}

// ============================================================
// APPLICATION ↔ CAPABILITY MAPPING
// ============================================================

model ApplicationCapabilityMap {
  applicationId String
  capabilityId  String
  workspaceId   String
  supportType   String   @default("SUPPORTS")
  notes         String?
  assignedAt    DateTime @default(now())

  application Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  capability  BusinessCapability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@id([applicationId, capabilityId])
  @@index([workspaceId, capabilityId])
  @@map("application_capability_maps")
}

// ============================================================
// APPLICATION ASSESSMENT
// ============================================================

model ApplicationAssessment {
  id                    String                @id @default(cuid())
  applicationId         String
  assessedById          String?
  businessValue         BusinessValueScore
  technicalHealth       TechnicalHealthScore
  rationalizationStatus RationalizationStatus
  notes                 String?
  assessedAt            DateTime              @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("application_assessments")
}

// ============================================================
// CAPABILITY MAP VERSIONING
// ============================================================

model CapabilityMapVersion {
  id          String   @id @default(cuid())
  workspaceId String
  label       String
  description String?
  snapshot    Json
  createdById String?
  isAutomatic Boolean  @default(false)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User?     @relation(fields: [createdById], references: [id])

  @@index([workspaceId, createdAt])
  @@map("capability_map_versions")
}

// ============================================================
// MODULE 3 ENUMS
// ============================================================

enum InitiativeStatus {
  DRAFT
  PLANNED
  IN_PROGRESS
  ON_HOLD
  COMPLETE
  CANCELLED
}

enum InitiativePriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum InitiativeCategory {
  MODERNISATION
  CONSOLIDATION
  DIGITALISATION
  COMPLIANCE
  OPTIMISATION
  INNOVATION
  DECOMMISSION
}

enum MilestoneStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
  BLOCKED
  CANCELLED
}

enum ArchStateType {
  AS_IS
  TO_BE
}

enum DependencyType {
  FINISH_TO_START
  FINISH_TO_FINISH
  START_TO_START
}

enum RoadmapHorizon {
  H1_NOW
  H2_NEXT
  H3_LATER
  BEYOND
}

// ============================================================
// MODULE 3: OBJECTIVE
// ============================================================

model Objective {
  id             String    @id @default(cuid())
  workspaceId    String
  name           String
  description    String?
  targetDate     DateTime?
  kpiDescription String?
  kpiTarget      String?
  ownerId        String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  workspace   Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner       User?                  @relation("ObjectiveOwner", fields: [ownerId], references: [id])
  initiatives InitiativeObjectiveMap[]

  @@index([workspaceId])
  @@map("objectives")
}

// ============================================================
// MODULE 3: INITIATIVE
// ============================================================

model Initiative {
  id              String             @id @default(cuid())
  workspaceId     String
  name            String
  description     String?
  category        InitiativeCategory @default(MODERNISATION)
  status          InitiativeStatus   @default(DRAFT)
  priority        InitiativePriority @default(MEDIUM)
  horizon         RoadmapHorizon     @default(H2_NEXT)
  startDate       DateTime?
  endDate         DateTime?
  budgetUsd       Decimal?           @db.Decimal(14, 2)
  budgetCurrency     String             @default("USD")
  cancellationReason String?
  sourceType         String?
  sourceContext      String?
  ownerId            String?
  businessSponsor    String?
  progressPct     Int                @default(0)
  ragStatus       String             @default("GREEN")
  isActive        Boolean            @default(true)
  sortOrder       Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  workspace    Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner        User?                    @relation("InitiativeOwner", fields: [ownerId], references: [id])
  milestones   Milestone[]
  capabilities InitiativeCapabilityMap[]
  applications InitiativeApplicationMap[]
  objectives   InitiativeObjectiveMap[]
  dependsOn    InitiativeDependency[]   @relation("DependentInitiative")
  blockedBy    InitiativeDependency[]   @relation("BlockingInitiative")
  archStates   ArchitectureState[]
  tags         InitiativeTagMap[]

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([workspaceId, horizon])
  @@map("initiatives")
}

// ============================================================
// MODULE 3: MILESTONE
// ============================================================

model Milestone {
  id           String          @id @default(cuid())
  initiativeId String
  workspaceId  String
  name         String
  description  String?
  status       MilestoneStatus @default(NOT_STARTED)
  dueDate      DateTime?
  completedAt  DateTime?
  ownerId      String?
  sortOrder    Int             @default(0)
  isCritical   Boolean         @default(false)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  initiative Initiative          @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  owner      User?               @relation("MilestoneOwner", fields: [ownerId], references: [id])
  blockedBy  MilestoneDependency[] @relation("DependentMilestone")
  blocks     MilestoneDependency[] @relation("BlockingMilestone")

  @@index([initiativeId])
  @@index([workspaceId])
  @@map("milestones")
}

// ============================================================
// MODULE 3: DEPENDENCIES
// ============================================================

model InitiativeDependency {
  id             String         @id @default(cuid())
  workspaceId    String
  dependentId    String
  blockingId     String
  dependencyType DependencyType @default(FINISH_TO_START)
  lagDays        Int            @default(0)
  notes          String?
  createdAt      DateTime       @default(now())

  dependent Initiative @relation("DependentInitiative", fields: [dependentId], references: [id], onDelete: Cascade)
  blocking  Initiative @relation("BlockingInitiative",  fields: [blockingId],  references: [id], onDelete: Cascade)

  @@unique([dependentId, blockingId])
  @@index([workspaceId])
  @@map("initiative_dependencies")
}

model MilestoneDependency {
  dependentId String
  blockingId  String
  createdAt   DateTime @default(now())

  dependent Milestone @relation("DependentMilestone", fields: [dependentId], references: [id], onDelete: Cascade)
  blocking  Milestone @relation("BlockingMilestone",  fields: [blockingId],  references: [id], onDelete: Cascade)

  @@id([dependentId, blockingId])
  @@map("milestone_dependencies")
}

// ============================================================
// MODULE 3: INITIATIVE ↔ CAPABILITY MAP
// ============================================================

model InitiativeCapabilityMap {
  initiativeId    String
  capabilityId    String
  workspaceId     String
  impactType      String   @default("IMPROVES")
  currentMaturity String?
  targetMaturity  String?
  notes           String?
  assignedAt      DateTime @default(now())

  initiative Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)

  @@id([initiativeId, capabilityId])
  @@index([workspaceId, capabilityId])
  @@map("initiative_capability_maps")
}

// ============================================================
// MODULE 3: INITIATIVE ↔ APPLICATION MAP
// ============================================================

model InitiativeApplicationMap {
  initiativeId  String
  applicationId String
  workspaceId   String
  changeType    String   @default("MODIFIES")
  notes         String?
  assignedAt    DateTime @default(now())

  initiative Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)

  @@id([initiativeId, applicationId])
  @@index([workspaceId, applicationId])
  @@map("initiative_application_maps")
}

// ============================================================
// MODULE 3: OBJECTIVE ↔ INITIATIVE MAP
// ============================================================

model InitiativeObjectiveMap {
  initiativeId String
  objectiveId  String
  assignedAt   DateTime @default(now())

  initiative Initiative @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  objective  Objective  @relation(fields: [objectiveId],  references: [id], onDelete: Cascade)

  @@id([initiativeId, objectiveId])
  @@map("initiative_objective_maps")
}

// ============================================================
// MODULE 3: ARCHITECTURE STATE (As-Is / To-Be snapshots)
// ============================================================

model ArchitectureState {
  id           String        @id @default(cuid())
  workspaceId  String
  initiativeId String?
  stateType    ArchStateType
  label        String
  description  String?
  snapshot     Json
  createdById  String?
  createdAt    DateTime      @default(now())

  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  initiative  Initiative? @relation(fields: [initiativeId], references: [id])
  createdBy   User?       @relation("ArchStateCreator", fields: [createdById], references: [id])

  @@index([workspaceId, stateType])
  @@index([initiativeId])
  @@map("architecture_states")
}

// ============================================================
// MODULE 3: INITIATIVE TAGS
// ============================================================

model InitiativeTag {
  id          String @id @default(cuid())
  workspaceId String
  name        String
  color       String @default("#6366f1")

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  mappings  InitiativeTagMap[]

  @@unique([workspaceId, name])
  @@map("initiative_tags")
}

model InitiativeTagMap {
  initiativeId String
  tagId        String
  assignedAt   DateTime @default(now())

  initiative Initiative    @relation(fields: [initiativeId], references: [id], onDelete: Cascade)
  tag        InitiativeTag @relation(fields: [tagId],        references: [id], onDelete: Cascade)

  @@id([initiativeId, tagId])
  @@map("initiative_tag_maps")
}

// ============================================================
// MODULE 4 ENUMS
// ============================================================

enum RadarRing {
  ADOPT
  TRIAL
  ASSESS
  HOLD
}

enum RadarQuadrant {
  LANGUAGES_FRAMEWORKS
  PLATFORMS_INFRASTRUCTURE
  TOOLS_TECHNIQUES
  DATA_STORAGE
}

enum RiskLikelihood {
  RARE
  LOW
  MEDIUM
  HIGH
}

enum RiskImpact {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskStatus {
  OPEN
  IN_PROGRESS
  MITIGATED
  ACCEPTED
  CLOSED
}

enum RiskCategory {
  TECHNOLOGY_EOL
  VENDOR_RISK
  SECURITY
  ARCHITECTURE
  CAPABILITY_GAP
  COMPLIANCE
  OPERATIONAL
  DATA
}

enum ComplianceFramework {
  SOC2_TYPE2
  ISO_27001
  GDPR
  PCI_DSS
  HIPAA
  NIST_CSF
  CIS_CONTROLS
  SOX
  PIPEDA
  CUSTOM
}

enum ComplianceMappingStatus {
  COMPLIANT
  PARTIAL
  NON_COMPLIANT
  NOT_ASSESSED
  EXEMPT
}

enum RemediationType {
  INITIATIVE_LINK
  MANUAL_ACTION
  ACCEPTED_RISK
  DEFERRED
}

// ============================================================
// MODULE 4: TECH RADAR
// ============================================================

model TechRadarEntry {
  id              String        @id @default(cuid())
  workspaceId     String
  techComponentId String?
  name            String
  quadrant        RadarQuadrant
  ring            RadarRing
  description     String?
  rationale       String?
  isNew           Boolean       @default(false)
  movedFrom       RadarRing?
  reviewedAt      DateTime?
  reviewedById    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  reviewedBy User?     @relation("RadarReviewer", fields: [reviewedById], references: [id])

  @@unique([workspaceId, name])
  @@index([workspaceId, ring])
  @@index([workspaceId, quadrant])
  @@map("tech_radar_entries")
}

// ============================================================
// MODULE 4: TECH RISK
// ============================================================

model TechRisk {
  id              String         @id @default(cuid())
  workspaceId     String
  title           String
  description     String?
  category        RiskCategory
  likelihood      RiskLikelihood
  impact          RiskImpact
  riskScore       Int
  status          RiskStatus     @default(OPEN)
  ownerId         String?
  dueDate         DateTime?
  identifiedAt    DateTime       @default(now())
  closedAt        DateTime?
  isAutoGenerated Boolean        @default(false)
  sourceType      String?
  sourceEntityId  String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  workspace        Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner            User?                @relation("RiskOwner", fields: [ownerId], references: [id])
  applicationLinks RiskApplicationLink[]
  capabilityLinks  RiskCapabilityLink[]
  remediations     RiskRemediation[]
  tags             RiskTagMap[]

  @@index([workspaceId, status])
  @@index([workspaceId, category])
  @@index([workspaceId, riskScore])
  @@map("tech_risks")
}

model RiskApplicationLink {
  riskId        String
  applicationId String
  workspaceId   String
  notes         String?
  assignedAt    DateTime @default(now())

  risk TechRisk @relation(fields: [riskId], references: [id], onDelete: Cascade)

  @@id([riskId, applicationId])
  @@index([workspaceId, applicationId])
  @@map("risk_application_links")
}

model RiskCapabilityLink {
  riskId       String
  capabilityId String
  workspaceId  String
  notes        String?
  assignedAt   DateTime @default(now())

  risk TechRisk @relation(fields: [riskId], references: [id], onDelete: Cascade)

  @@id([riskId, capabilityId])
  @@index([workspaceId, capabilityId])
  @@map("risk_capability_links")
}

model RiskRemediation {
  id              String          @id @default(cuid())
  riskId          String
  workspaceId     String
  remediationType RemediationType
  initiativeId    String?
  description     String?
  targetDate      DateTime?
  completedDate   DateTime?
  createdAt       DateTime        @default(now())

  risk TechRisk @relation(fields: [riskId], references: [id], onDelete: Cascade)

  @@index([riskId])
  @@index([workspaceId])
  @@map("risk_remediations")
}

// ============================================================
// MODULE 4: RISK TAGS
// ============================================================

model RiskTag {
  id          String @id @default(cuid())
  workspaceId String
  name        String
  color       String @default("#6366f1")

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  mappings  RiskTagMap[]

  @@unique([workspaceId, name])
  @@map("risk_tags")
}

model RiskTagMap {
  riskId     String
  tagId      String
  assignedAt DateTime @default(now())

  risk TechRisk @relation(fields: [riskId], references: [id], onDelete: Cascade)
  tag  RiskTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([riskId, tagId])
  @@map("risk_tag_maps")
}

// ============================================================
// MODULE 4: COMPLIANCE
// ============================================================

model ComplianceRequirement {
  id              String              @id @default(cuid())
  workspaceId     String
  framework       ComplianceFramework
  controlId       String
  title           String
  description     String?
  category        String?
  isApplicable    Boolean             @default(true)
  isMandatory     Boolean             @default(true)
  auditFrequency  String?
  evidenceNotes   String?
  sortOrder       Int                 @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  workspace Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  mappings  ComplianceMapping[]

  @@unique([workspaceId, framework, controlId])
  @@index([workspaceId, framework])
  @@map("compliance_requirements")
}

model ComplianceMapping {
  id             String                  @id @default(cuid())
  requirementId  String
  workspaceId    String
  entityType     String
  entityId       String
  entityName     String
  status         ComplianceMappingStatus @default(NOT_ASSESSED)
  evidence       String?
  assessedById   String?
  assessedAt     DateTime?
  nextReviewDate DateTime?
  notes          String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  requirement  ComplianceRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  assessedBy   User?                 @relation("ComplianceAssessor", fields: [assessedById], references: [id])

  @@unique([requirementId, entityType, entityId])
  @@index([workspaceId, requirementId])
  @@map("compliance_mappings")
}

// ============================================================
// MODULE 4: EOL WATCH
// ============================================================

model EolWatchEntry {
  id                    String    @id @default(cuid())
  workspaceId           String
  entityType            String
  entityId              String
  entityName            String
  eolDate               DateTime?
  eosDate               DateTime?
  vendor                String?
  affectedAppCount      Int       @default(0)
  urgencyBand           String    @default("HEALTHY")
  remediationInitiativeId String?
  isAcknowledged        Boolean   @default(false)
  acknowledgedById      String?
  acknowledgedAt        DateTime?
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  acknowledgedBy User?     @relation("EolAcknowledger", fields: [acknowledgedById], references: [id])

  @@unique([workspaceId, entityType, entityId])
  @@index([workspaceId, urgencyBand])
  @@map("eol_watch_entries")
}

// ============================================================
// DASHBOARD PINS
// ============================================================

model DashboardPin {
  id          String   @id @default(cuid())
  workspaceId String
  entityType  String
  entityId    String
  label       String
  href        String
  createdAt   DateTime @default(now())
  createdById String

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation(fields: [createdById], references: [id])

  @@unique([workspaceId, entityType, entityId])
  @@index([workspaceId])
  @@map("dashboard_pins")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id          String      @id @default(cuid())
  workspaceId String
  userId      String?
  action      AuditAction
  entityType  String
  entityId    String
  before      Json?
  after       Json?
  createdAt   DateTime    @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id])

  @@index([workspaceId, entityType])
  @@index([workspaceId, createdAt])
  @@map("audit_logs")
}
