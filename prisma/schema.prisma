  HIPAA
  NIST_CSF
  CIS_CONTROLS
  SOX
  PIPEDA
  DORA
  NIS2
  ISO_27701
  FEDRAMP_MODERATE
  CUSTOM
}

enum ComplianceMappingStatus {
  COMPLIANT
  PARTIAL
  NON_COMPLIANT
  NOT_ASSESSED
  EXEMPT
}

enum RemediationType {
  INITIATIVE_LINK
  MANUAL_ACTION
