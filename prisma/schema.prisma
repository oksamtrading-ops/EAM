// ============================================================
// MODULE 4 ENUMS
// ============================================================

enum RadarRing {
  ADOPT
  TRIAL
  ASSESS
  HOLD
}

enum RadarQuadrant {
  LANGUAGES_FRAMEWORKS
  PLATFORMS_INFRASTRUCTURE
  TOOLS_TECHNIQUES
  DATA_STORAGE
}

enum RiskLikelihood {
  RARE
  LOW
  MEDIUM
  HIGH
}

enum RiskImpact {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskStatus {
  OPEN
  IN_PROGRESS
  MITIGATED
  ACCEPTED
  CLOSED
}

enum RiskCategory {
  TECHNOLOGY_EOL
  VENDOR_RISK
  SECURITY
  ARCHITECTURE
  CAPABILITY_GAP
  COMPLIANCE
  OPERATIONAL
  DATA
}

