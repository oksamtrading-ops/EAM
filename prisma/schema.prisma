// ============================================================
// MODULE 7: VENDOR
// ============================================================

model Vendor {
  id                    String         @id @default(cuid())
  workspaceId           String
  name                  String
  website               String?
  category              VendorCategory @default(OTHER)
  description           String?
  headquartersCountry   String?
  annualSpend           Decimal?       @db.Decimal(14, 2)
  currency              String         @default("USD")
  contractNotes         String?
  relationshipOwnerId   String?
  status                VendorStatus   @default(ACTIVE)
  isActive              Boolean        @default(true)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  workspace         Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  relationshipOwner User?               @relation("VendorRelationshipOwner", fields: [relationshipOwnerId], references: [id])
  products          TechnologyProduct[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([workspaceId, category])
  @@map("vendors")
}

// ============================================================
// MODULE 7: TECHNOLOGY PRODUCT (catalog level)
// ============================================================

model TechnologyProduct {
  id               String         @id @default(cuid())
  workspaceId      String
  vendorId         String
  name             String
  slug             String
  type             TechnologyType @default(OTHER)
  category         String?
  description      String?
  website          String?
  openSource       Boolean        @default(false)
  licenseType      LicenseType    @default(UNKNOWN)
  techRadarEntryId String?
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  workspace       Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  vendor          Vendor                 @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  versions        TechnologyVersion[]
  components      TechnologyComponent[]
  dependenciesOut TechnologyDependency[] @relation("DependencySource")
  dependenciesIn  TechnologyDependency[] @relation("DependencyTarget")
  standards       TechnologyStandard[]
  referenceArchs  ReferenceArchitectureComponent[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([workspaceId, type])
  @@index([workspaceId, vendorId])
  @@index([workspaceId, techRadarEntryId])
  @@map("technology_products")
}

// ============================================================
// MODULE 7: TECHNOLOGY VERSION
// ============================================================

model TechnologyVersion {
  id               String          @id @default(cuid())
  workspaceId      String
  productId        String
  version          String
  releaseDate      DateTime?
  endOfSupportDate DateTime?
  endOfLifeDate    DateTime?
  lifecycleStatus  LifecycleStatus @default(CURRENT)
  notes            String?
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  workspace       Workspace                        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  product         TechnologyProduct                @relation(fields: [productId], references: [id], onDelete: Cascade)
  components      TechnologyComponent[]
  standards       TechnologyStandard[]
  referenceArchs  ReferenceArchitectureComponent[]

  @@unique([productId, version])
  @@index([workspaceId])
  @@index([workspaceId, productId])
  @@index([workspaceId, lifecycleStatus])
  @@index([workspaceId, endOfLifeDate])
  @@map("technology_versions")
}

// ============================================================
// MODULE 7: TECHNOLOGY COMPONENT (deployment level — ArchiMate Node)
// ============================================================

model TechnologyComponent {
  id           String               @id @default(cuid())
  workspaceId  String
  productId    String
  versionId    String?
  name         String
  environment  ComponentEnvironment @default(PRODUCTION)
  hostingModel HostingModel         @default(ON_PREMISES)
  region       String?
  ownerId      String?
  notes        String?
  isActive     Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  workspace    Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  product      TechnologyProduct       @relation(fields: [productId], references: [id], onDelete: Restrict)
  version      TechnologyVersion?      @relation(fields: [versionId], references: [id])
  owner        User?                   @relation("TechnologyComponentOwner", fields: [ownerId], references: [id])
  applications ApplicationTechnology[]

  @@index([workspaceId])
  @@index([workspaceId, productId])
  @@index([workspaceId, environment])
  @@index([workspaceId, hostingModel])
  @@map("technology_components")
}

// ============================================================
// MODULE 7: APPLICATION ↔ TECHNOLOGY COMPONENT LINK
// ============================================================
// NOTE: This is distinct from the M4 ApplicationTechLink (TechRadar link),
// which remains intact for backward compatibility.

model ApplicationTechnology {
  applicationId String
  componentId   String
  layer         TechLayer             @default(APPLICATION)
  role          TechnologyRole        @default(PRIMARY)
  criticality   TechnologyCriticality @default(STANDARD)
  notes         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  application Application         @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  component   TechnologyComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@id([applicationId, componentId])
  @@index([componentId])
  @@map("application_technologies")
}

// ============================================================
// MODULE 7: TECHNOLOGY DEPENDENCY (tech → tech)
// ============================================================

model TechnologyDependency {
  id                String                   @id @default(cuid())
  workspaceId       String
  sourceProductId   String
  targetProductId   String
  dependencyType    TechnologyDependencyType @default(REQUIRES)
  versionConstraint String?
  notes             String?
  isActive          Boolean                  @default(true)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  workspace     Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceProduct TechnologyProduct @relation("DependencySource", fields: [sourceProductId], references: [id], onDelete: Cascade)
  targetProduct TechnologyProduct @relation("DependencyTarget", fields: [targetProductId], references: [id], onDelete: Cascade)

  @@unique([sourceProductId, targetProductId, dependencyType])
  @@index([workspaceId])
  @@index([workspaceId, sourceProductId])
  @@index([workspaceId, targetProductId])
  @@map("technology_dependencies")
}

// ============================================================
// MODULE 7 PHASE 2: TECHNOLOGY STANDARDS + REFERENCE ARCHITECTURES
// ============================================================

enum StandardCategory {
  PRODUCT_CHOICE
  VERSION_CHOICE
  PROTOCOL
  SECURITY
  ARCHITECTURE_PATTERN
  HOSTING
  INTEGRATION
  DATA
  OTHER
}

enum StandardLevel {
  MANDATORY
  RECOMMENDED
  DEPRECATED
  PROHIBITED
}

enum StandardStatus {
  DRAFT
  ACTIVE
  RETIRED
}

enum ReferenceArchStatus {
  DRAFT
  ACTIVE
  DEPRECATED
}

model TechnologyStandard {
  id             String           @id @default(cuid())
  workspaceId    String
  name           String
  description    String?
  category       StandardCategory @default(OTHER)
  level          StandardLevel    @default(RECOMMENDED)
  status         StandardStatus   @default(ACTIVE)
  productId      String?
  versionId      String?
  ownerId        String?
  effectiveDate  DateTime?
  reviewDate     DateTime?
  rationale      String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  workspace Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  product   TechnologyProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)
  version   TechnologyVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)
  owner     User?              @relation("TechnologyStandardOwner", fields: [ownerId], references: [id])

  @@index([workspaceId])
  @@index([workspaceId, category])
  @@index([workspaceId, level])
  @@index([workspaceId, status])
  @@index([workspaceId, productId])
  @@index([workspaceId, versionId])
  @@map("technology_standards")
}

model ReferenceArchitecture {
  id          String              @id @default(cuid())
  workspaceId String
  name        String
  slug        String
  description String?
  category    String?
  status      ReferenceArchStatus @default(DRAFT)
  ownerId     String?
  diagramUrl  String?
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  workspace  Workspace                       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner      User?                           @relation("ReferenceArchitectureOwner", fields: [ownerId], references: [id])
  components ReferenceArchitectureComponent[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([workspaceId, status])
  @@map("reference_architectures")
}

model ReferenceArchitectureComponent {
  architectureId String
  productId      String
  layer          TechLayer      @default(APPLICATION)
  role           TechnologyRole @default(PRIMARY)
  versionId      String?
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  architecture ReferenceArchitecture @relation(fields: [architectureId], references: [id], onDelete: Cascade)
  product      TechnologyProduct     @relation(fields: [productId], references: [id], onDelete: Cascade)
  version      TechnologyVersion?    @relation(fields: [versionId], references: [id], onDelete: SetNull)

  @@id([architectureId, productId])
  @@index([productId])
  @@map("reference_architecture_components")
}

// ============================================================
// HORIZON 1 — AGENTIC AI FOUNDATIONS
// Document intake pipeline + approval queue + agent-run trace
// ============================================================

enum IntakeStatus {
  PENDING
  PROCESSING
  EXTRACTED
  FAILED
}

enum IntakeEntityType {
  CAPABILITY
  APPLICATION
  RISK
  VENDOR
  TECH_COMPONENT
  INITIATIVE
}

enum DraftStatus {
  PENDING
  ACCEPTED
  REJECTED
  MODIFIED
}

enum AgentRunStatus {
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

model IntakeDocument {
  id          String       @id @default(cuid())
  workspaceId String
  filename    String
  mimeType    String
  sizeBytes   Int
  storageKey  String       // Vercel Blob key or inline-data marker
  status      IntakeStatus @default(PENDING)
  errorMessage String?
  uploadedBy  String
  uploadedAt  DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  chunks          IntakeChunk[]
  drafts          IntakeDraft[]
  knowledgeDrafts KnowledgeDraft[]

  @@index([workspaceId, status])
  @@map("intake_documents")
}

model IntakeChunk {
  id         String @id @default(cuid())
  documentId String
  ordinal    Int
  text       String
  page       Int?

  embedding Unsupported("vector(1536)")?

  createdAt DateTime @default(now())

  document IntakeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("intake_chunks")
}

model IntakeDraft {
  id                String           @id @default(cuid())
  workspaceId       String
  documentId        String?
  entityType        IntakeEntityType
  payload           Json
  confidence        Float            @default(0)
  evidence          Json             @default("[]")
  status            DraftStatus      @default(PENDING)
  reviewedBy        String?
  reviewedAt        DateTime?
  rejectionReason   String?
  committedEntityId String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  document  IntakeDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, entityType])
  @@index([documentId])
  @@map("intake_drafts")
}

model AgentRun {
  id             String         @id @default(cuid())
  workspaceId    String
  conversationId String?
  parentRunId    String?
  kind           String         // "palette" | "intake" | "rationalization-critic" | "console" | "sub-agent:*"
  status         AgentRunStatus @default(RUNNING)
  inputHash      String
  promptVersion  String?
  model          String?
  totalTokensIn  Int            @default(0)
  totalTokensOut Int            @default(0)
  errorMessage   String?
  startedAt      DateTime       @default(now())
  endedAt        DateTime?

  workspace    Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation AgentConversation?        @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  parent       AgentRun?                 @relation("AgentRunSubRuns", fields: [parentRunId], references: [id], onDelete: Cascade)
  subRuns      AgentRun[]                @relation("AgentRunSubRuns")
  messages     AgentConversationMessage[]
  steps        AgentRunStep[]
  knowledge    WorkspaceKnowledge[]
  knowledgeDrafts KnowledgeDraft[]
  scheduledTasks ScheduledAgentTask[]

  @@index([workspaceId, kind, startedAt])
  @@index([conversationId])
  @@index([parentRunId])
  @@map("agent_runs")
}

model AgentRunStep {
  id        String   @id @default(cuid())
  runId     String
  ordinal   Int
  kind      String   // "llm" | "tool_call" | "tool_result" | "error"
  toolName  String?
  payload   Json
  latencyMs Int?
  createdAt DateTime @default(now())

  run AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, ordinal])
  @@map("agent_run_steps")
}

model AgentConversation {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  title       String
  kind        String   @default("console")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AgentConversationMessage[]
  runs      AgentRun[]
  share     AgentConversationShare?

  @@index([workspaceId, updatedAt])
  @@index([userId, updatedAt])
  @@map("agent_conversations")
}

model AgentConversationMessage {
  id             String   @id @default(cuid())
  conversationId String
  ordinal        Int
  role           String   // "user" | "assistant"
  content        String
  toolCalls      Json?    // assistant turns: [{ id, name, input, ok, output? }]
  runId          String?
  createdAt      DateTime @default(now())

  conversation AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  run          AgentRun?         @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([conversationId, ordinal])
  @@map("agent_conversation_messages")
}

// ============================================================
// WORKSPACE KNOWLEDGE — agent-curated facts about the workspace
// ============================================================

enum WorkspaceKnowledgeKind {
  FACT
  DECISION
  PATTERN
}

model WorkspaceKnowledge {
  id          String                 @id @default(cuid())
  workspaceId String
  kind        WorkspaceKnowledgeKind @default(FACT)
  subject     String                 // e.g. "Salesforce Sales Cloud" or "Core banking stack"
  statement   String                 // the fact itself
  confidence  Float                  @default(0.8)
  embedding   Unsupported("vector(1536)")?
  sourceRunId String?
  createdBy   String?                // User.id of author (null = agent)
  isActive    Boolean                @default(true)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  // Null = never re-confirmed since initial commit. Used with
  // WorkspaceAgentSettings.staleKnowledgeDays to flag aging facts in
  // the UI and decay retrieval rank (see retrieveKnowledge).
  lastReviewedAt DateTime?

  workspace     Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceRun     AgentRun?        @relation(fields: [sourceRunId], references: [id], onDelete: SetNull)
  draftSource   KnowledgeDraft[] @relation("KnowledgeDraftCommit")
  similarDrafts KnowledgeDraft[] @relation("KnowledgeDraftDedup")

  @@index([workspaceId, isActive, updatedAt])
  @@index([workspaceId, subject])
  @@map("workspace_knowledge")
}

model KnowledgeDraft {
  id                   String                 @id @default(cuid())
  workspaceId          String
  sourceDocumentId     String?
  kind                 WorkspaceKnowledgeKind @default(FACT)
  subject              String
  statement            String
  confidence           Float                  @default(0.8)
  evidence             Json                   @default("[]")
  status               DraftStatus            @default(PENDING)
  sourceRunId          String?
  reviewedBy           String?
  reviewedAt           DateTime?
  rejectionReason      String?
  committedKnowledgeId String?
  similarKnowledgeId   String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceDocument     IntakeDocument?     @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  sourceRun          AgentRun?           @relation(fields: [sourceRunId], references: [id], onDelete: SetNull)
  committedKnowledge WorkspaceKnowledge? @relation("KnowledgeDraftCommit", fields: [committedKnowledgeId], references: [id], onDelete: SetNull)
  similarKnowledge   WorkspaceKnowledge? @relation("KnowledgeDraftDedup", fields: [similarKnowledgeId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status])
  @@index([sourceDocumentId])
  @@index([similarKnowledgeId])
  @@map("knowledge_drafts")
}

// ============================================================
// SCHEDULED AGENT TASKS — cron-style recurring agent runs
// ============================================================

enum ScheduledTaskNotifyMode {
  NEVER
  ON_FAILURE
  ALWAYS
}

model ScheduledAgentTask {
  id             String    @id @default(cuid())
  workspaceId    String
  userId         String    // owner; runs use this user's Clerk id for auth scope
  name           String
  prompt         String
  cronExpression String    // standard 5-field cron
  enabled        Boolean   @default(true)
  lastRunAt      DateTime?
  lastRunId      String?
  nextRunAt      DateTime?
  // Email notifications. Null notifyEmail or NEVER mode = silent. When
  // set, executeScheduledTask fires a Resend email per notifyMode. The
  // email call fails open if RESEND_API_KEY is missing.
  notifyEmail    String?
  notifyMode     ScheduledTaskNotifyMode @default(NEVER)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastRun   AgentRun? @relation(fields: [lastRunId], references: [id], onDelete: SetNull)

  @@index([workspaceId, enabled, nextRunAt])
  @@index([userId])
  @@map("scheduled_agent_tasks")
}



// ============================================================
// WORKSPACE AGENT SETTINGS — per-workspace tunables
// ============================================================

model WorkspaceAgentSettings {
  workspaceId          String   @id
  maxToolIterations    Int      @default(6)
  subAgentBudget       Int      @default(3)
  llmMaxTokens         Int      @default(1500)
  autoAcceptConfidence Float?
  criticEnabled        Boolean  @default(true)
  // Facts with updatedAt older than this many days are flagged "stale"
  // in the UI and have their retrieval rank decayed. Default 90 days.
  staleKnowledgeDays   Int      @default(90)
  updatedAt            DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_agent_settings")
}


model AgentConversationShare {
  id              String    @id @default(cuid())
  conversationId  String    @unique
  slug            String    @unique
  title           String?
  redactToolCalls Boolean   @default(true)
  expiresAt       DateTime?
  createdBy       String
  revoked         Boolean   @default(false)
  createdAt       DateTime  @default(now())

  conversation AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User              @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([slug])
  @@map("agent_conversation_shares")
}
