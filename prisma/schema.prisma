// ============================================================
// EAM PLATFORM — PRISMA SCHEMA (POC)
// Module 1: Business Capability Map
// Stack: PostgreSQL + pgvector (Neon)
// ============================================================

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

// ============================================================
// ENUMS
// ============================================================

enum IndustryType {
  BANKING
  RETAIL
  LOGISTICS
  MANUFACTURING
  HEALTHCARE
  GENERIC
}

enum CapabilityLevel {
  L1
  L2
  L3
}

enum StrategicImportance {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  NOT_ASSESSED
}

enum MaturityLevel {
  INITIAL
  DEVELOPING
  DEFINED
  MANAGED
  OPTIMIZING
  NOT_ASSESSED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  IMPORT
  ASSESS
}

// ============================================================
// MODULE 2 ENUMS
// ============================================================

enum ApplicationLifecycle {
  PLANNED
  ACTIVE
  PHASING_OUT
  RETIRED
  SUNSET
}

enum ApplicationType {
  SAAS
  COTS
  CUSTOM
  PAAS
  OPEN_SOURCE
  LEGACY
}

enum DeploymentModel {
  CLOUD_PUBLIC
  CLOUD_PRIVATE
  ON_PREMISE
  HYBRID
  SAAS_HOSTED
  UNKNOWN
}

enum BusinessValueScore {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  BV_UNKNOWN
}

enum TechnicalHealthScore {
  EXCELLENT
  GOOD
  FAIR
  POOR
  TH_CRITICAL
  TH_UNKNOWN
}

enum RationalizationStatus {
  KEEP
  INVEST
  MIGRATE
  RETIRE
  CONSOLIDATE
  EVALUATE
  RAT_NOT_ASSESSED
}

// ============================================================
// USER (synced from Clerk)
// ============================================================

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaces         Workspace[]
  ownedCapabilities  BusinessCapability[] @relation("CapabilityOwner")
  auditLogs          AuditLog[]
  createdVersions    CapabilityMapVersion[]
  ownedApplications  Application[] @relation("AppOwner")

  @@map("users")
}

// ============================================================
// WORKSPACE (single default for POC)
// ============================================================

model Workspace {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  clientName  String?
  description String?
  industry    IndustryType @default(GENERIC)
  logoUrl     String?
  userId      String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  capabilities  BusinessCapability[]
  organizations Organization[]
  auditLogs     AuditLog[]
  tags          CapabilityTag[]
  versions      CapabilityMapVersion[]
  applications  Application[]

  @@map("workspaces")
}

// ============================================================
// ORGANIZATION (Business Unit)
// ============================================================

model Organization {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?
  parentId    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace    Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent       Organization?  @relation("OrgHierarchy", fields: [parentId], references: [id])
  children     Organization[] @relation("OrgHierarchy")
  capabilities BusinessCapability[]

  @@map("organizations")
}

// ============================================================
// BUSINESS CAPABILITY
// ============================================================

model BusinessCapability {
  id                  String              @id @default(cuid())
  workspaceId         String
  parentId            String?
  level               CapabilityLevel     @default(L1)
  name                String
  description         String?
  ownerId             String?
  organizationId      String?
  strategicImportance StrategicImportance @default(NOT_ASSESSED)
  currentMaturity     MaturityLevel       @default(NOT_ASSESSED)
  targetMaturity      MaturityLevel       @default(NOT_ASSESSED)
  sortOrder           Int                 @default(0)
  isActive            Boolean             @default(true)
  externalId          String?

  embedding Unsupported("vector(1536)")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace    Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent       BusinessCapability?  @relation("CapabilityTree", fields: [parentId], references: [id])
  children     BusinessCapability[] @relation("CapabilityTree")
  owner        User?                @relation("CapabilityOwner", fields: [ownerId], references: [id])
  organization Organization?        @relation(fields: [organizationId], references: [id])
  tags         CapabilityTagMap[]
  assessments  CapabilityAssessment[]
  applicationMappings ApplicationCapabilityMap[]

  @@index([workspaceId])
  @@index([workspaceId, parentId])
  @@index([workspaceId, level])
  @@map("business_capabilities")
}

// ============================================================
// TAGS
// ============================================================

model CapabilityTag {
  id          String  @id @default(cuid())
  workspaceId String
  name        String
  color       String  @default("#6366f1")
  description String?

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  mappings  CapabilityTagMap[]

  @@unique([workspaceId, name])
  @@map("capability_tags")
}

model CapabilityTagMap {
  capabilityId String
  tagId        String
  assignedAt   DateTime @default(now())

  capability BusinessCapability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)
  tag        CapabilityTag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([capabilityId, tagId])
  @@map("capability_tag_maps")
}

// ============================================================
// CAPABILITY ASSESSMENT
// ============================================================

model CapabilityAssessment {
  id                  String              @id @default(cuid())
  capabilityId        String
  assessedById        String?
  currentMaturity     MaturityLevel
  targetMaturity      MaturityLevel
  strategicImportance StrategicImportance
  notes               String?
  assessedAt          DateTime            @default(now())

  capability BusinessCapability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@index([capabilityId])
  @@map("capability_assessments")
}

// ============================================================
// INDUSTRY TEMPLATES
// ============================================================

model CapabilityTemplate {
  id          String          @id @default(cuid())
  industry    IndustryType
  level       CapabilityLevel
  name        String
  description String?
  parentCode  String?
  code        String          @unique
  sortOrder   Int             @default(0)
  isActive    Boolean         @default(true)

  @@index([industry, level])
  @@map("capability_templates")
}

// ============================================================
// MODULE 2: APPLICATION
// ============================================================

model Application {
  id                    String                @id @default(cuid())
  workspaceId           String
  name                  String
  description           String?
  alias                 String?
  vendor                String?
  version               String?
  applicationType       ApplicationType       @default(CUSTOM)
  deploymentModel       DeploymentModel       @default(UNKNOWN)
  lifecycle             ApplicationLifecycle  @default(ACTIVE)
  lifecycleStartDate    DateTime?
  lifecycleEndDate      DateTime?
  businessValue         BusinessValueScore    @default(BV_UNKNOWN)
  technicalHealth       TechnicalHealthScore  @default(TH_UNKNOWN)
  rationalizationStatus RationalizationStatus @default(RAT_NOT_ASSESSED)
  rationalizationNotes  String?
  annualCostUsd         Decimal?              @db.Decimal(14, 2)
  businessOwnerName     String?
  itOwnerName           String?
  ownerId               String?
  sortOrder             Int                   @default(0)
  isActive              Boolean               @default(true)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  workspace    Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner        User?                    @relation("AppOwner", fields: [ownerId], references: [id])
  capabilities ApplicationCapabilityMap[]
  assessments  ApplicationAssessment[]

  @@index([workspaceId])
  @@index([workspaceId, lifecycle])
  @@index([workspaceId, rationalizationStatus])
  @@map("applications")
}

// ============================================================
// APPLICATION ↔ CAPABILITY MAPPING
// ============================================================

model ApplicationCapabilityMap {
  applicationId String
  capabilityId  String
  workspaceId   String
  supportType   String   @default("SUPPORTS")
  notes         String?
  assignedAt    DateTime @default(now())

  application Application        @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  capability  BusinessCapability @relation(fields: [capabilityId], references: [id], onDelete: Cascade)

  @@id([applicationId, capabilityId])
  @@index([workspaceId, capabilityId])
  @@map("application_capability_maps")
}

// ============================================================
// APPLICATION ASSESSMENT
// ============================================================

model ApplicationAssessment {
  id                    String                @id @default(cuid())
  applicationId         String
  assessedById          String?
  businessValue         BusinessValueScore
  technicalHealth       TechnicalHealthScore
  rationalizationStatus RationalizationStatus
  notes                 String?
  assessedAt            DateTime              @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("application_assessments")
}

// ============================================================
// CAPABILITY MAP VERSIONING
// ============================================================

model CapabilityMapVersion {
  id          String   @id @default(cuid())
  workspaceId String
  label       String
  description String?
  snapshot    Json
  createdById String?
  isAutomatic Boolean  @default(false)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User?     @relation(fields: [createdById], references: [id])

  @@index([workspaceId, createdAt])
  @@map("capability_map_versions")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id          String      @id @default(cuid())
  workspaceId String
  userId      String?
  action      AuditAction
  entityType  String
  entityId    String
  before      Json?
  after       Json?
  createdAt   DateTime    @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id])

  @@index([workspaceId, entityType])
  @@index([workspaceId, createdAt])
  @@map("audit_logs")
}
